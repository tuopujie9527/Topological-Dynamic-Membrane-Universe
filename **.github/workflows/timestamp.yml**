yaml
name: Create Trusted Timestamp

on:
  push:
    branches: [ main ]  # 当你push到main分支时触发
  schedule:
    - cron: '0 0 * * *'   # 每天UTC 0:00自动运行一次（可选）

jobs:
  timestamp:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3
        with:
          fetch-depth: 0  # 获取完整历史，必需
        
      - name: Create Trusted Timestamp
        uses: timestampit/action@v1
        with:
          # 证明文件将保存在这个分支
          target_branch: trusted_timestamps
